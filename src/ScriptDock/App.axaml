<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ScriptDock.App"
             xmlns:conv="using:ScriptDock.Converters"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- Semantic dark palette. ScriptDock is dark-only by design (no theme switch), so the
             tokens are a single flat set rather than per-variant dictionaries. This is the one
             source of truth for the app's colours: code that cannot reach a StaticResource (the
             script-tile colour converter and the code-built dialogs) resolves these by key via
             ScriptDock.Palette, so nothing duplicates a hex value. -->
        <Color x:Key="AppBackground">#0F181D</Color>
        <Color x:Key="Surface">#16252B</Color>
        <Color x:Key="Border">#2B414A</Color>
        <Color x:Key="TextPrimary">#E8F2F4</Color>
        <Color x:Key="TextSecondary">#93A9B0</Color>

        <!-- Electric console: cyan actions use dark ink; danger remains a separate semantic red. -->
        <Color x:Key="Accent">#22D3EE</Color>
        <Color x:Key="AccentHover">#67E8F9</Color>
        <Color x:Key="AccentForeground">#062126</Color>
        <Color x:Key="AccentDisabled">#174650</Color>
        <Color x:Key="AccentForegroundDisabled">#B4C4C8</Color>
        <Color x:Key="Danger">#BE3455</Color>
        <Color x:Key="DangerHover">#C83A58</Color>

        <!-- State colours. DangerText is danger red as *text* on a dark surface (validation
             errors, removed scripts) — lighter than the danger button fill for legibility.
             ScriptNew is the orange dot flagging a newly-found script — an accent, not a
             background tint; ScriptHidden
             dims hidden scripts; Running is the green run indicator. -->
        <Color x:Key="DangerText">#FB7185</Color>
        <Color x:Key="ScriptNew">#FB923C</Color>
        <Color x:Key="ScriptHidden">#718991</Color>
        <Color x:Key="Running">#4ADE80</Color>
        <Color x:Key="ContentWell">#081216</Color>
        <Color x:Key="Selection">#153843</Color>
        <Color x:Key="SelectionHover">#1B4653</Color>
        <Color x:Key="SelectionSecondary">#B4C4C8</Color>
        <Color x:Key="ChipBackground">#14242B</Color>
        <Color x:Key="ChipHover">#1B3139</Color>
        <Color x:Key="ChipSelected">#193640</Color>
        <Color x:Key="DisabledInput">#081115</Color>
        <Color x:Key="DisabledInputBorder">#182A31</Color>
        <Color x:Key="DisabledText">#5F747B</Color>

        <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>

        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}"/>
        <SolidColorBrush x:Key="AccentForegroundBrush" Color="{StaticResource AccentForeground}"/>
        <SolidColorBrush x:Key="AccentDisabledBrush" Color="{StaticResource AccentDisabled}"/>
        <SolidColorBrush x:Key="AccentForegroundDisabledBrush" Color="{StaticResource AccentForegroundDisabled}"/>
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHover}"/>

        <SolidColorBrush x:Key="DangerTextBrush" Color="{StaticResource DangerText}"/>
        <SolidColorBrush x:Key="ScriptNewBrush" Color="{StaticResource ScriptNew}"/>
        <SolidColorBrush x:Key="ScriptHiddenBrush" Color="{StaticResource ScriptHidden}"/>
        <SolidColorBrush x:Key="RunningBrush" Color="{StaticResource Running}"/>
        <SolidColorBrush x:Key="ContentWellBrush" Color="{StaticResource ContentWell}"/>
        <SolidColorBrush x:Key="SelectionBrush" Color="{StaticResource Selection}"/>
        <SolidColorBrush x:Key="SelectionHoverBrush" Color="{StaticResource SelectionHover}"/>
        <SolidColorBrush x:Key="SelectionSecondaryBrush" Color="{StaticResource SelectionSecondary}"/>
        <SolidColorBrush x:Key="ChipBackgroundBrush" Color="{StaticResource ChipBackground}"/>
        <SolidColorBrush x:Key="ChipHoverBrush" Color="{StaticResource ChipHover}"/>
        <SolidColorBrush x:Key="ChipSelectedBrush" Color="{StaticResource ChipSelected}"/>
        <SolidColorBrush x:Key="DisabledInputBrush" Color="{StaticResource DisabledInput}"/>
        <SolidColorBrush x:Key="DisabledInputBorderBrush" Color="{StaticResource DisabledInputBorder}"/>
        <SolidColorBrush x:Key="DisabledTextBrush" Color="{StaticResource DisabledText}"/>

        <conv:ScriptItemColorConverter x:Key="ScriptColor"/>

        <!-- Scroll-bar theming. Fluent's default ScrollBar thumb/track brushes are NOT remapped to
             this app's custom palette, so left alone the bar reads off-theme. Remap the Fluent
             thumb-fill resource keys (referenced as DynamicResources inside the Fluent ScrollBar
             template) to the app's existing palette brushes — the resting thumb is the same Border
             colour used across the UI, brightening to the secondary-text colour on hover/press — and
             keep the track transparent so the bar is a slim thumb over the content. ScrollBarSize is
             the template's thickness token; 10px gives the thin, modern bar the conventions call for.
             The CornerRadius that makes the thumb a pill is set on the Thumb in Application.Styles. -->
        <x:Double x:Key="ScrollBarSize">10</x:Double>
        <SolidColorBrush x:Key="ScrollBarPanningThumbBackground" Color="{StaticResource Border}"/>
        <SolidColorBrush x:Key="ScrollBarThumbFill" Color="{StaticResource Border}"/>
        <SolidColorBrush x:Key="ScrollBarThumbFillPointerOver" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="ScrollBarThumbFillPressed" Color="{StaticResource TextSecondary}"/>
        <SolidColorBrush x:Key="ScrollBarTrackFill" Color="Transparent"/>
        <SolidColorBrush x:Key="ScrollBarTrackFillPointerOver" Color="Transparent"/>
        <SolidColorBrush x:Key="ScrollBarBackground" Color="Transparent"/>
        <SolidColorBrush x:Key="ScrollBarBackgroundPointerOver" Color="Transparent"/>

        <!-- The app-wide UI (chrome) font. The default is the bundled Inter; the view model overrides
             this resource at runtime from the configured UI font, and the Window style below binds it
             via DynamicResource so the change applies live across every window. -->
        <FontFamily x:Key="AppFontFamily">Inter</FontFamily>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme>
            <FluentTheme.Palettes>
                <ColorPaletteResources x:Key="Dark"
                                       Accent="{StaticResource Accent}"
                                       RegionColor="{StaticResource AppBackground}"
                                       ErrorText="{StaticResource Danger}"/>
            </FluentTheme.Palettes>
        </FluentTheme>
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>

        <!-- Every window (main + dialogs) takes the configured UI font; FontFamily inherits to child
             controls. The read-only output console sets its own monospace font, so it is unaffected. -->
        <Style Selector="Window">
            <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}"/>
        </Style>

        <!-- Keep DataGrid cell navigation active without drawing a harsh current-cell box. -->
        <Style Selector="DataGridCell">
            <Setter Property="FocusAdorner" Value="{x:Null}"/>
        </Style>
        <Style Selector="DataGridCell:current /template/ Rectangle#CurrencyVisual">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
        <Style Selector="DataGridCell:focus /template/ Grid#FocusVisual">
            <Setter Property="IsVisible" Value="False"/>
        </Style>

        <!-- Dialog accent (commit) button -->
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentForegroundBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.accent /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentForegroundBrush}"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentForegroundBrush}"/>
        </Style>
        <!-- Disabled commit remains readable while clearly receding from the live cyan action. -->
        <Style Selector="Button.accent:disabled">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Background" Value="{StaticResource AccentDisabledBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentForegroundDisabledBrush}"/>
        </Style>
        <Style Selector="Button.accent:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource AccentDisabledBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource AccentForegroundDisabledBrush}"/>
        </Style>

        <!-- Dialog destructive button -->
        <Style Selector="Button.destructive">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.destructive:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerHoverBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Launcher surfaces: card panels, card headers, and compact toolbar buttons. -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <!-- A card's header strip: the title/toolbar row set off from the content by a single bottom
             border line. Used by a card with Padding=0 so the line spans the full width. The fixed
             height keeps every section header the same height regardless of whether it holds toolbar
             buttons (Scripts/Recent) or just a title (Output); horizontal-only padding leaves the
             centered content to sit consistently within that height. -->
        <Style Selector="Border.sectionHeader">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
        <Style Selector="TextBlock.cardHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.tool">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Lists are recessed content wells; selected rows use a quiet cyan tint, not a solid accent. -->
        <Style Selector="ListBox">
            <Setter Property="Background" Value="{StaticResource ContentWellBrush}"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource ChipHoverBrush}"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SelectionBrush}"/>
        </Style>
        <Style Selector="ListBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SelectionHoverBrush}"/>
        </Style>

        <!-- Consistent text-input border colour (the Fluent default reads near-black). -->
        <Style Selector="TextBox">
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>
        <Style Selector="TextBox.stdin:disabled">
            <Setter Property="Background" Value="{StaticResource DisabledInputBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}"/>
            <Setter Property="PlaceholderForeground" Value="{StaticResource DisabledTextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DisabledInputBorderBrush}"/>
        </Style>
        <Style Selector="TextBox.stdin:disabled /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{StaticResource DisabledInputBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DisabledInputBorderBrush}"/>
        </Style>

        <!-- Thin, rounded, palette-themed scroll bars everywhere (per the window-chrome
             conventions). Applied globally so the console ScrollViewer, both main ListBoxes, and the
             Settings lists all match. The slim thickness comes from the ScrollBarSize resource
             override above; here the thumb is rounded into a pill. The thumb's fill colour (resting
             vs. hover/press) is driven by the remapped Fluent resources above, so this style only
             needs the shape — keeping it template-version-robust. CornerRadius 5 on a 10px bar makes
             the thumb fully rounded (a pill) in both orientations. -->
        <Style Selector="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="ScrollBar /template/ Thumb">
            <Setter Property="CornerRadius" Value="5"/>
        </Style>
    </Application.Styles>
</Application>
