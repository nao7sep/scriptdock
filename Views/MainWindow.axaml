<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ScriptDock.ViewModels"
        xmlns:models="using:ScriptDock.Models"
        x:Class="ScriptDock.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ScriptDock"
        Width="1100" Height="720" MinWidth="860" MinHeight="540"
        KeyDown="OnWindowKeyDown"
        Background="{StaticResource AppBackgroundBrush}">

    <Window.Resources>
        <!-- Content-sized script tile: new → amber bg, removed → red text, hidden → gray; a green dot when running. -->
        <DataTemplate x:Key="ScriptTile" x:DataType="models:ScriptItem">
            <Border Background="{Binding Converter={StaticResource ScriptColor}, ConverterParameter=bg}"
                    CornerRadius="4" Padding="8,5" Margin="2">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Ellipse Width="7" Height="7" Fill="#16A34A" VerticalAlignment="Center" IsVisible="{Binding IsRunning}"/>
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="{Binding Converter={StaticResource ScriptColor}, ConverterParameter=fg}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- Top toolbar: wordmark, primary actions, hamburger -->
        <Border DockPanel.Dock="Top" Classes="card" Margin="0,0,0,10">
            <DockPanel>
                <TextBlock Text="ScriptDock" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                <Button Content="☰" Classes="tool" DockPanel.Dock="Right" FontSize="16">
                    <Button.Flyout>
                        <MenuFlyout Placement="BottomEdgeAlignedRight">
                            <MenuItem x:Name="SettingsMenuItem" Header="Settings" Click="OnSettingsClick"/>
                            <MenuItem x:Name="ShortcutsMenuItem" Header="Keyboard Shortcuts" Click="OnShortcutsClick"/>
                            <MenuItem Header="About" Click="OnAboutClick"/>
                            <MenuItem Header="Reveal Logs" Click="OnRevealLogsClick"/>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Button Content="Rescan" Classes="accent" Command="{Binding RescanCommand}"/>
                    <CheckBox Content="Show hidden" IsChecked="{Binding ShowHidden}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Classes="card" Margin="0,10,0,0" Padding="10,6">
            <DockPanel>
                <TextBlock Text="Scanning…" DockPanel.Dock="Right" IsVisible="{Binding IsScanning}"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondaryBrush}"/>
            </DockPanel>
        </Border>

        <!-- Body: lists row, splitter, console row -->
        <Grid x:Name="BodyGrid" RowDefinitions="*,6,220">

            <Grid x:Name="ListsGrid" Grid.Row="0" ColumnDefinitions="*,6,340">

                <!-- Scripts (content-sized tiles) -->
                <Border Grid.Column="0" Classes="card">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                            <TextBlock Text="Scripts" Classes="cardHeader" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                <Button Content="Run" Classes="tool" Command="{Binding RunScriptCommand}" CommandParameter="{Binding #ScriptsList.SelectedItem}"/>
                                <Button Content="Hide / Show" Classes="tool" Command="{Binding ToggleHiddenCommand}" CommandParameter="{Binding #ScriptsList.SelectedItem}"/>
                            </StackPanel>
                        </DockPanel>
                        <ListBox x:Name="ScriptsList" ItemsSource="{Binding Scripts}"
                                 ItemTemplate="{StaticResource ScriptTile}"
                                 DoubleTapped="OnScriptDoubleTapped" KeyDown="OnScriptKeyDown">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" Width="6" Background="Transparent" ResizeDirection="Columns"/>

                <!-- Recent (running + recently-run, dismissible) -->
                <Border Grid.Column="2" Classes="card">
                    <DockPanel>
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                            <TextBlock Text="Recent" Classes="cardHeader" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                                <Button Content="Run" Classes="tool" Command="{Binding RunOrRestartCommand}" CommandParameter="{Binding #RecentList.SelectedItem}"/>
                                <Button Content="Stop" Classes="tool" Command="{Binding StopEntryCommand}" CommandParameter="{Binding #RecentList.SelectedItem}"/>
                                <Button Content="Dismiss" Classes="tool" Command="{Binding DismissEntryCommand}" CommandParameter="{Binding #RecentList.SelectedItem}"/>
                            </StackPanel>
                        </DockPanel>
                        <ListBox x:Name="RecentList" ItemsSource="{Binding Recent}"
                                 SelectedItem="{Binding SelectedDockEntry, Mode=TwoWay}"
                                 DoubleTapped="OnRecentDoubleTapped" KeyDown="OnRecentKeyDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:DockEntry">
                                    <DockPanel>
                                        <TextBlock Text="{Binding StateText}" DockPanel.Dock="Right" Margin="8,0,0,0"
                                                   VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding LastRanDisplay}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>

            <GridSplitter Grid.Row="1" Height="6" Background="Transparent" ResizeDirection="Rows" HorizontalAlignment="Stretch"/>

            <!-- Console: the selected Recent item's output -->
            <Border Grid.Row="2" Classes="card">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6" Margin="0,0,0,6">
                        <TextBlock Text="Output" Classes="cardHeader"/>
                        <TextBlock Text="{Binding SelectedDockEntry.DisplayName}" Classes="cardHeader"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                    <TextBox Text="{Binding SelectedOutput}" IsReadOnly="True" AcceptsReturn="True"
                             TextWrapping="NoWrap" FontFamily="Menlo,Consolas,monospace" FontSize="12"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
