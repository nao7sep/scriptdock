<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ScriptDock.ViewModels"
        x:Class="ScriptDock.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="ScriptDock"
        Width="1000" Height="640"
        Background="{StaticResource AppBackgroundBrush}">

    <!-- Phase 0 scaffold: the real launcher UI (script/favorites/recently-run/process
         lists, toolbars, and the output pane) lands in Phase 4. -->
    <TextBlock Text="{Binding Placeholder}"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               FontSize="16"
               Foreground="{StaticResource TextSecondaryBrush}"/>

</Window>
